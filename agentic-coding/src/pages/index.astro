---
import Base from '@brandon_m_behring/book-scaffold-astro/layouts/Base.astro';
import { getCollection } from 'astro:content';

// Agentic Coding groups its chapters by the numeric `part` (1–5 + appendices in
// part 6). NOTE: Representation/Operation/Evolution is the *per-chapter* skeleton
// (see 00-design.mdx) — it is NOT the book's table of contents. Part display names
// below are derived from the chapter clusters.
//
// Chapters route at the book base-root `/<id>/` (see src/pages/[...slug].astro,
// params.slug = entry.id) — NOT under /chapters/. Links are base-prefixed via
// import.meta.env.BASE_URL (= '/agentic-coding/'), matching the hardcoded-base
// cross-link convention used inside the chapters.
const BASE = import.meta.env.BASE_URL;
const href = (id) => `${BASE}${id}/`;

const PARTS = [
  { part: 1, title: 'Foundations', blurb: 'How an agent represents the work — its mental model, context as a budgeted resource, and prompting as specification.' },
  { part: 2, title: 'The working loop', blurb: 'The day-to-day cycle — running sessions, the edit–test–commit loop, and thinking through problems with the agent.' },
  { part: 3, title: 'Extending & delegating', blurb: 'Scaling a single agent — briefing documents, custom tools and skills, and parallel sub-agents.' },
  { part: 4, title: 'Projects, teams & production', blurb: 'Working at real scale — starting and refactoring projects, recovering from anti-patterns, automation pipelines, team governance, and enterprise deployment.' },
  { part: 5, title: 'Evolution & audit', blurb: 'Staying current — how agentic practices evolve across tools, and how to audit your own practice.' },
];

const chapters = await getCollection('chapters', (entry) => entry.data.draft !== true);
const num = (id) => id.split('-')[0]; // leading "01".."16" or "a".."f"
const byPart = (p) =>
  chapters
    .filter((c) => (c.data.part ?? 0) === p)
    .sort((a, b) => a.id.localeCompare(b.id));
const appendices = byPart(6);
const about = chapters.find((c) => c.id === '00-design');
---
<Base
  title="Agentic Coding"
  description="Engineering with AI coding agents — Claude Code, Gemini CLI, and Codex CLI — as a single cross-tool practice. Principle-first, with every chapter tracking where the tools converge and diverge."
>
  <article class="prose">
    <h1>Agentic Coding</h1>
    <p class="subtitle"><em>Engineering with AI coding agents — Claude Code · Gemini CLI · Codex CLI</em></p>

    <p>A cross-tool, principle-first guide to building software with AI coding agents. Every chapter
    follows the same skeleton — <strong>Representation</strong> (how each tool models the idea),
    <strong>Operation</strong> (how practitioners work with it day to day), and
    <strong>Evolution</strong> (where the tools converge and diverge) — so a practice you learn here
    outlives any single release.</p>

    {about && (
      <p><strong>New here? Start with <a href={href(about.id)}>How this book is designed</a></strong> —
      the reading guide to chapter structure, freshness stamps, and the convergence/divergence model.</p>
    )}

    <h2>Chapters</h2>
    {PARTS.map((p) => {
      const chs = byPart(p.part);
      if (chs.length === 0) return null;
      return (
        <section>
          <h3>Part {p.part} · {p.title}</h3>
          <p class="part-blurb">{p.blurb}</p>
          <ul>
            {chs.map((c) => (
              <li>
                <a href={href(c.id)}><strong>{num(c.id)}</strong> · {c.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      );
    })}

    {appendices.length > 0 && (
      <section>
        <h3>Appendices</h3>
        <ul>
          {appendices.map((c) => (
            <li><a href={href(c.id)}>{c.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>
