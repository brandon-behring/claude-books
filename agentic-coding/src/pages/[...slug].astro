---
/**
 * [...slug].astro — dynamic route for every chapter in src/content/chapters.
 *
 * getStaticPaths emits one page per non-draft chapter; the page imports
 * the Chapter layout and renders the MDX body via <Content />.
 *
 * Path shape: the collection's slug (filename minus extension) becomes
 * the URL. E.g. `src/content/chapters/context-as-currency.mdx` → `/context-as-currency/`.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import Chapter from '@brandon_m_behring/book-scaffold-astro/layouts/Chapter.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const chapters = await getCollection(
    'chapters',
    (entry) => entry.data.draft !== true,
  );
  return chapters.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<Chapter entry={entry} headings={headings}>
  <Content />
</Chapter>
