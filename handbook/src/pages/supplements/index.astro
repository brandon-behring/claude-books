---
/**
 * /supplements — index of the handbook's supplement layer (tutorials, how-tos,
 * TL;DRs, cheat-sheets, part-summaries) that accompany the canonical chapters.
 *
 * Published supplements (Part I) are grouped by chapter; draft supplements
 * (ch05–08 + part2-summary, pending the Part II port) are segregated into a
 * clearly-labeled "Drafts" section and noindexed on their own pages.
 */
import { getCollection } from 'astro:content';

const entries = await getCollection('supplements');
const published = entries.filter((e) => !e.data.draft);
const drafts = entries.filter((e) => e.data.draft);

type Group = { label: string; entries: typeof entries };

function groupByChapter(list: typeof entries): [string, Group][] {
  const groups: Map<string, Group> = new Map();
  for (const e of [...list].sort((a, b) => a.id.localeCompare(b.id))) {
    let key: string;
    let label: string;
    if (e.data.kind === 'part-summary') {
      key = `zz-part-${e.data.part_source ?? 0}`;
      label = `Part ${e.data.part_source ?? '?'} — summary`;
    } else if (e.data.chapter_source !== undefined) {
      key = `ch-${String(e.data.chapter_source).padStart(2, '0')}`;
      label = `Chapter ${e.data.chapter_source}`;
    } else {
      key = 'zz-other';
      label = 'Other';
    }
    if (!groups.has(key)) groups.set(key, { label, entries: [] });
    groups.get(key)!.entries.push(e);
  }
  return [...groups.entries()].sort(([a], [b]) => a.localeCompare(b));
}

const chapterGroupsSorted = groupByChapter(published);
const draftGroupsSorted = groupByChapter(drafts);

// Group published by kind (secondary view)
const kindOrder = ['tutorial', 'how-to', 'tldr', 'cheat-sheet', 'part-summary'];
const byKind: Record<string, typeof entries> = {};
for (const e of published) {
  (byKind[e.data.kind] ??= []).push(e);
}

const kindColor = (kind: string): string => {
  const colors: Record<string, string> = {
    'tutorial': '#0066cc',
    'how-to': '#0a8754',
    'tldr': '#9d5cd1',
    'cheat-sheet': '#c2410c',
    'part-summary': '#4b5563',
  };
  return colors[kind] ?? '#666';
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Handbook supplements — tutorials, how-tos, TL;DRs, cheat-sheets</title>
    <style>
      :root {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
      }
      body {
        max-width: 80ch;
        margin: 2rem auto;
        padding: 0 1.5rem;
      }
      h1 { margin-bottom: 0.25rem; }
      p.subtitle { color: #555; margin-top: 0; margin-bottom: 0.5rem; }
      h2 { margin-top: 2.5rem; margin-bottom: 0.5rem; }
      h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; font-weight: 600; font-size: 1.05rem; }
      ul { padding-left: 0; list-style: none; }
      li { margin-bottom: 0.6rem; }
      a.poc-link { color: #1a1a1a; text-decoration: none; border-bottom: 1px solid #cbd5e1; }
      a.poc-link:hover { border-bottom-color: #0066cc; color: #0066cc; }
      .kind-chip {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-radius: 0.25rem;
        color: white;
        margin-right: 0.5rem;
        vertical-align: middle;
      }
      .description { color: #555; font-size: 0.875rem; display: block; margin-top: 0.15rem; padding-left: 0; }
      .stats { color: #888; font-size: 0.875rem; }
      details.alt-view summary { cursor: pointer; color: #555; padding: 0.5rem 0; }
      details.alt-view summary:hover { color: #0066cc; }
      details.alt-view { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e5e7eb; }
      section.drafts { margin-top: 3rem; padding-top: 1.5rem; border-top: 2px solid #fde68a; }
      section.drafts h2 { color: #78350f; }
      section.drafts .draft-note { color: #92400e; font-size: 0.95rem; margin-top: -0.25rem; }
    </style>
  </head>
  <body>
    <h1>Handbook supplements</h1>
    <p class="subtitle">
      The handbook's secondary-disclosure layer — alternate ways to consume each chapter:
      a long-form tutorial, a focused how-to, a TL;DR, and a cheat-sheet, plus per-Part summaries.
    </p>
    <p class="stats">
      <strong>{published.length} published</strong>
      {drafts.length > 0 && <> &nbsp;·&nbsp; {drafts.length} draft</>}
      &nbsp;·&nbsp; {Object.keys(byKind).length} formats
      &nbsp;·&nbsp; See <code>handbook/poc/COMPARISON.md</code> in the repo for the format-experiment memos.
    </p>

    <h2>By chapter</h2>
    <p style="color: #555; font-size: 0.95rem; margin-top: -0.5rem;">
      All formats for one chapter together — the canonical chapter links each of these from its
      "Go deeper" block.
    </p>
    {chapterGroupsSorted.map(([key, group]) => (
      <>
        <h3>{group.label}</h3>
        <ul>
          {group.entries.map((e) => (
            <li>
              <span class="kind-chip" style={`background-color: ${kindColor(e.data.kind)};`}>{e.data.kind}</span>
              <a class="poc-link" href={`/supplements/${e.id}`}>{e.data.title}</a>
              {e.data.description && <span class="description">{e.data.description}</span>}
            </li>
          ))}
        </ul>
      </>
    ))}

    <details class="alt-view">
      <summary><strong>By format</strong> — all tutorials together, all cheat sheets together, etc.</summary>
      {kindOrder.map((kind) => byKind[kind] && (
        <>
          <h3>
            <span class="kind-chip" style={`background-color: ${kindColor(kind)};`}>{kind}</span>
            <span style="text-transform: capitalize;">{kind.replace('-', ' ')}</span>
          </h3>
          <ul>
            {byKind[kind].map((e) => (
              <li>
                <a class="poc-link" href={`/supplements/${e.id}`}>{e.data.title}</a>
              </li>
            ))}
          </ul>
        </>
      ))}
    </details>

    {draftGroupsSorted.length > 0 && (
      <section class="drafts">
        <h2>Drafts — pending Part II port</h2>
        <p class="draft-note">
          These supplements were drafted ahead of their canonical chapters (Part II, ch05–08). They
          build + are directly linkable for preview, but are noindexed and not yet wired into chapters.
        </p>
        {draftGroupsSorted.map(([key, group]) => (
          <>
            <h3>{group.label}</h3>
            <ul>
              {group.entries.map((e) => (
                <li>
                  <span class="kind-chip" style={`background-color: ${kindColor(e.data.kind)};`}>{e.data.kind}</span>
                  <a class="poc-link" href={`/supplements/${e.id}`}>{e.data.title}</a>
                  {e.data.description && <span class="description">{e.data.description}</span>}
                </li>
              ))}
            </ul>
          </>
        ))}
      </section>
    )}
  </body>
</html>
