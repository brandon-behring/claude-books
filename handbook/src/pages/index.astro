---
import Base from '@brandon_m_behring/book-scaffold-astro/layouts/Base.astro';
import { getCollection } from 'astro:content';

const chapters = await getCollection('chapters', (entry) => !entry.data.draft);
chapters.sort((a, b) => (a.data.chapter ?? 0) - (b.data.chapter ?? 0));
---
<Base title="Best Practices for Using Claude" description="Astro port of the LaTeX handbook claude-best-practices v2.9.">
  <article class="prose">
    <h1>Best Practices for Using Claude</h1>
    <p><em>Astro port of the LaTeX handbook <code>claude-best-practices</code> v2.9. Phase 0 of an ongoing port — only chapter 1 is live so far.</em></p>

    <h2>Chapters</h2>
    <ul>
      {chapters.map((c) => (
        <li>
          <a href={`/chapters/${c.id}/`}>
            {c.data.chapter ? `Chapter ${c.data.chapter}: ` : ''}{c.data.title}
          </a>
        </li>
      ))}
    </ul>

    <h2>Other pages</h2>
    <ul>
      <li><a href="/chapters/">Chapter listing</a> (auto-generated)</li>
      <li><a href="/search/">Search</a> (Pagefind)</li>
      <li><a href="/references/">References</a></li>
      <li><a href="/print/">Print view</a></li>
      <li><a href="/convergence/">Convergence dashboard</a></li>
    </ul>
  </article>
</Base>
