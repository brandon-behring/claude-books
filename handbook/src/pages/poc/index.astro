---
/**
 * /poc — index page listing all PoCs for visual side-by-side comparison.
 *
 * Two groupings offered:
 * 1. By chapter (default) — easiest for "see Ch 5's 4 formats together"
 * 2. By kind (collapsible) — easiest for "see all the cheat-sheets in one view"
 */
import { getCollection } from 'astro:content';

const entries = await getCollection('poc');
const sorted = [...entries].sort((a, b) => a.id.localeCompare(b.id));

// Group by chapter / part
type Group = { label: string; entries: typeof entries };
const chapterGroups: Map<string, Group> = new Map();
for (const e of sorted) {
  let key: string;
  let label: string;
  if (e.data.poc_kind === 'part-summary') {
    key = `zz-part-${e.data.part_source ?? 0}`;
    label = `Part ${e.data.part_source ?? '?'} — summary`;
  } else if (e.data.chapter_source !== undefined) {
    key = `ch-${String(e.data.chapter_source).padStart(2, '0')}`;
    label = `Chapter ${e.data.chapter_source}`;
  } else {
    key = 'zz-other';
    label = 'Other';
  }
  if (!chapterGroups.has(key)) chapterGroups.set(key, { label, entries: [] });
  chapterGroups.get(key)!.entries.push(e);
}
const chapterGroupsSorted = [...chapterGroups.entries()].sort(([a], [b]) => a.localeCompare(b));

// Group by kind (secondary view)
const kindOrder = ['tutorial', 'how-to', 'tldr', 'cheat-sheet', 'part-summary'];
const byKind: Record<string, typeof entries> = {};
for (const e of sorted) {
  (byKind[e.data.poc_kind] ??= []).push(e);
}

const kindColor = (kind: string): string => {
  const colors: Record<string, string> = {
    'tutorial': '#0066cc',
    'how-to': '#0a8754',
    'tldr': '#9d5cd1',
    'cheat-sheet': '#c2410c',
    'part-summary': '#4b5563',
  };
  return colors[kind] ?? '#666';
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Handbook PoCs — pedagogical visual exploration</title>
    <style>
      :root {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
      }
      body {
        max-width: 80ch;
        margin: 2rem auto;
        padding: 0 1.5rem;
      }
      h1 { margin-bottom: 0.25rem; }
      p.subtitle { color: #555; margin-top: 0; margin-bottom: 0.5rem; }
      h2 { margin-top: 2.5rem; margin-bottom: 0.5rem; }
      h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; font-weight: 600; font-size: 1.05rem; }
      ul { padding-left: 0; list-style: none; }
      li { margin-bottom: 0.6rem; }
      a.poc-link { color: #1a1a1a; text-decoration: none; border-bottom: 1px solid #cbd5e1; }
      a.poc-link:hover { border-bottom-color: #0066cc; color: #0066cc; }
      .kind-chip {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-radius: 0.25rem;
        color: white;
        margin-right: 0.5rem;
        vertical-align: middle;
      }
      .description { color: #555; font-size: 0.875rem; display: block; margin-top: 0.15rem; padding-left: 0; }
      .stats { color: #888; font-size: 0.875rem; }
      details.alt-view summary { cursor: pointer; color: #555; padding: 0.5rem 0; }
      details.alt-view summary:hover { color: #0066cc; }
      details.alt-view { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e5e7eb; }
    </style>
  </head>
  <body>
    <h1>Handbook PoCs</h1>
    <p class="subtitle">
      Pedagogical proof-of-concepts for the handbook's content-type taxonomy.
      Ch 1 (Foundations) + Ch 5-8 (Personal Practice) rendered under multiple supplement formats for side-by-side visual comparison.
    </p>
    <p class="stats">
      <strong>{entries.length} PoCs</strong>
      &nbsp;·&nbsp; {Object.keys(byKind).length} formats
      &nbsp;·&nbsp; See <code>handbook/poc/COMPARISON.md</code> in the repo for the synthesis memos.
    </p>

    <h2>By chapter</h2>
    <p style="color: #555; font-size: 0.95rem; margin-top: -0.5rem;">
      All formats for one chapter together — easiest for visually comparing how the same content renders under different registers.
    </p>
    {chapterGroupsSorted.map(([key, group]) => (
      <>
        <h3>{group.label}</h3>
        <ul>
          {group.entries.map((e) => (
            <li>
              <span class="kind-chip" style={`background-color: ${kindColor(e.data.poc_kind)};`}>{e.data.poc_kind}</span>
              <a class="poc-link" href={`/poc/${e.id}`}>{e.data.title}</a>
              {e.data.description && <span class="description">{e.data.description}</span>}
            </li>
          ))}
        </ul>
      </>
    ))}

    <details class="alt-view">
      <summary><strong>By format</strong> — all tutorials together, all cheat sheets together, etc.</summary>
      {kindOrder.map((kind) => byKind[kind] && (
        <>
          <h3>
            <span class="kind-chip" style={`background-color: ${kindColor(kind)};`}>{kind}</span>
            <span style="text-transform: capitalize;">{kind.replace('-', ' ')}</span>
          </h3>
          <ul>
            {byKind[kind].map((e) => (
              <li>
                <a class="poc-link" href={`/poc/${e.id}`}>{e.data.title}</a>
              </li>
            ))}
          </ul>
        </>
      ))}
    </details>
  </body>
</html>
