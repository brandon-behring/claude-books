---
import Base from '@brandon_m_behring/book-scaffold-astro/layouts/Base.astro';
import { getCollection } from 'astro:content';

const chapters = await getCollection('chapters', (entry) => !entry.data.draft);
chapters.sort((a, b) => (a.data.chapter ?? 0) - (b.data.chapter ?? 0));
---
<Base title="The Claude Architect's Reference (Cert-Aligned)" description="The cert-aligned volume of the claude-books series — mapped to Anthropic's Claude Certified Architect — Foundations domains D1–D5. References the Agentic Systems Design book for design depth.">
  <article class="prose">
    <h1>The Claude Architect's Reference</h1>
    <p class="subtitle"><em>Cert-Aligned — Claude Certified Architect: Foundations (D1–D5)</em></p>

    <p>This volume maps 1:1 to Anthropic's <strong>Claude Certified Architect — Foundations</strong> five-domain taxonomy. It is exam-prep altitude: it owns the cert spine and points outward to the <strong>Agentic Systems Design</strong> book where a domain needs design depth.</p>

    <h2>Status</h2>
    <p>Skeleton — the five-domain outline is in <code>OUTLINE.md</code>; chapters are authored in a later round. See <code>docs/BOOK-MAP.md</code> for how this book relates to the others.</p>

    <h2>Chapters</h2>
    {chapters.length === 0
      ? <p><em>No chapters yet — see <code>OUTLINE.md</code> for the D1–D5 plan.</em></p>
      : <ul>{chapters.map((c) => (<li><a href={`/chapters/${c.id}/`}>{c.data.chapter ? `Chapter ${c.data.chapter}: ` : ''}{c.data.title}</a></li>))}</ul>}
  </article>
</Base>
